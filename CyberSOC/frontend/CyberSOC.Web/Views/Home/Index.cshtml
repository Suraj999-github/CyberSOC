@{
    ViewData["Title"] = "Dashboard";
}

<!-- ── Stats bar ──────────────────────────────────────────────── -->
<div class="row g-3 mb-4" id="statsBar">
    <div class="col-6 col-sm-4 col-md-2">
        <div class="soc-stat-card text-center">
            <div class="soc-stat-value" id="statTotal">0</div>
            <div class="soc-stat-label">Total Alerts</div>
        </div>
    </div>
    <div class="col-6 col-sm-4 col-md-2">
        <div class="soc-stat-card text-center" style="border-color:#c0392b33">
            <div class="soc-stat-value text-danger" id="statCritical">0</div>
            <div class="soc-stat-label">Critical</div>
        </div>
    </div>
    <div class="col-6 col-sm-4 col-md-2">
        <div class="soc-stat-card text-center" style="border-color:#e74c3c33">
            <div class="soc-stat-value" style="color:#e74c3c" id="statHigh">0</div>
            <div class="soc-stat-label">High</div>
        </div>
    </div>
    <div class="col-6 col-sm-4 col-md-2">
        <div class="soc-stat-card text-center" style="border-color:#f39c1233">
            <div class="soc-stat-value text-warning" id="statMedium">0</div>
            <div class="soc-stat-label">Medium</div>
        </div>
    </div>
    <div class="col-6 col-sm-4 col-md-2">
        <div class="soc-stat-card text-center" style="border-color:#3498db33">
            <div class="soc-stat-value text-info" id="statLow">0</div>
            <div class="soc-stat-label">Low</div>
        </div>
    </div>
    <div class="col-6 col-sm-4 col-md-2">
        <div class="soc-stat-card text-center" style="border-color:#95a5a633">
            <div class="soc-stat-value text-secondary" id="statInfo">0</div>
            <div class="soc-stat-label">Informational</div>
        </div>
    </div>
</div>

<!-- ── Chart row ──────────────────────────────────────────────── -->
<div class="row g-3 mb-4">

    <!-- Severity bar chart -->
    <div class="col-12 col-lg-5">
        <div class="card soc-card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>
                    <i class="bi bi-bar-chart-fill me-2 text-warning"></i>
                    Severity Distribution
                </span>
                <span class="text-secondary small" id="chartUpdated">—</span>
            </div>
            <div class="card-body chart-body">
                <canvas id="severityChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Severity breakdown table -->
    <div class="col-12 col-lg-3">
        <div class="card soc-card h-100">
            <div class="card-header">
                <i class="bi bi-list-ol me-2 text-info"></i>
                Severity Breakdown
            </div>
            <div class="card-body p-0">
                <table class="table table-dark table-sm mb-0 soc-table">
                    <thead class="soc-thead">
                        <tr>
                            <th>Level</th>
                            <th class="text-end">Count</th>
                            <th class="text-end">%</th>
                        </tr>
                    </thead>
                    <tbody id="severityBreakdown">
                        <!-- populated by JS -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Connection + last-alert panel -->
    <div class="col-12 col-lg-4">
        <div class="card soc-card mb-3">
            <div class="card-header">
                <i class="bi bi-wifi me-2 text-success"></i>
                Connection Info
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush soc-info-list">
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-secondary">Hub URL</span>
                        <code id="infoHubUrl" class="text-truncate ms-2" style="max-width:180px">—</code>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-secondary">State</span>
                        <span id="infoState">—</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-secondary">Connected at</span>
                        <span id="infoConnectedAt">—</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between">
                        <span class="text-secondary">Reconnects</span>
                        <span id="infoReconnects">0</span>
                    </li>
                </ul>
            </div>
        </div>

        <div class="card soc-card">
            <div class="card-header">
                <i class="bi bi-bell-fill me-2 text-danger"></i>
                Last Alert
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush soc-info-list" id="lastAlertPanel">
                    <li class="list-group-item text-secondary small">No alert received yet</li>
                </ul>
            </div>
        </div>
    </div>

</div>

<!-- ── Live Alert Feed ─────────────────────────────────────────── -->
<div class="row g-3">
    <div class="col-12">
        <div class="card soc-card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>
                    <i class="bi bi-activity me-2 text-danger"></i>
                    Live Alert Feed
                </span>
                <div class="d-flex align-items-center gap-3">
                    <!-- Filter -->
                    <select id="severityFilter" class="form-select form-select-sm soc-select" style="width:auto">
                        <option value="">All Severities</option>
                        <option value="Critical">Critical</option>
                        <option value="High">High</option>
                        <option value="Medium">Medium</option>
                        <option value="Low">Low</option>
                        <option value="Informational">Informational</option>
                    </select>
                    <span class="badge bg-secondary rounded-pill" id="alertCount">0</span>
                </div>
            </div>
            <div class="card-body p-0">

                <!-- Empty state -->
                <div id="emptyState" class="text-center text-secondary py-5">
                    <i class="bi bi-clock-history fs-1 d-block mb-3 opacity-50"></i>
                    <div class="fw-semibold">No alerts yet</div>
                    <div class="small mt-1">Waiting for events from the WebApi hub…</div>
                </div>

                <!-- Alert table -->
                <div id="alertTableWrapper" class="d-none">
                    <div class="table-responsive soc-table-scroll">
                        <table class="table table-dark table-hover table-sm mb-0 align-middle soc-table">
                            <thead class="soc-thead sticky-top">
                                <tr>
                                    <th style="width:110px">Severity</th>
                                    <th style="width:140px">Type</th>
                                    <th>Title</th>
                                    <th style="width:130px">Source IP</th>
                                    <th style="width:90px">Raised At</th>
                                    <th style="width:36px"></th>
                                </tr>
                            </thead>
                            <tbody id="alertTableBody">
                                <!-- rows injected by site.js -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ── Alert detail modal ─────────────────────────────────────── -->
<div class="modal fade" id="alertDetailModal" tabindex="-1" aria-labelledby="alertDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content soc-modal">
            <div class="modal-header border-secondary">
                <h5 class="modal-title" id="alertDetailModalLabel">
                    <i class="bi bi-shield-exclamation me-2"></i>Alert Detail
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="alertDetailBody">
                <!-- populated by JS -->
            </div>
            <div class="modal-footer border-secondary">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>
