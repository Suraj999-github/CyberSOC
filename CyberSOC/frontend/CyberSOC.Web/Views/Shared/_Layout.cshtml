@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration
<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CyberSOC Command Center</title>

    <!-- Bootstrap 5 (dark theme capable) -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <!-- App styles -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- ── Top Navigation Bar ─────────────────────────────────── -->
    <nav class="navbar navbar-dark soc-navbar px-3">
        <span class="navbar-brand soc-brand">
            <i class="bi bi-shield-lock-fill me-2 text-danger"></i>
            CyberSOC Command Center
        </span>
        <!-- Connection status injected by JS -->
        <div id="connectionStatus" class="d-flex align-items-center gap-2 text-secondary small">
            <span id="statusDot" class="status-dot bg-secondary"></span>
            <span id="statusText">Connecting…</span>
        </div>
    </nav>

    <!-- ── Page Content ───────────────────────────────────────── -->
    <main class="container-fluid py-4 px-4">
        @RenderBody()
    </main>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmCA3P8TtxD9KuWY+Ue2X8MKNXDQ"
            crossorigin="anonymous"></script>

    <!-- Microsoft SignalR client -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

    <!-- Chart.js for the severity bar chart -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>

    <!-- Hub URL from appsettings.json → SignalR:HubUrl (read once, server-side) -->
    <script>
        window.ALERTS_HUB_URL = '@Html.Raw(Configuration["SignalR:HubUrl"] ?? "/hubs/alerts")';
    </script>

    <!-- App JS -->
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
